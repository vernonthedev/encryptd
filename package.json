{
  "name": "@vernonthedev/encryptd",
  "version": "0.0.1",
  "author": "vernonthedev",
  "description": "Rust based Env Encryption Package.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "secure-env": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "napi-build": "napi build --manifest-path rust/Cargo.toml --platform --release",
    "prepublishOnly": "pnpm run napi-build && pnpm run build",
    "test": "vitest run"
  },
  "napi": {
    "binaryName": "encryptd",
    "cargoCwd": "rust",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/vernonthedev/encryptd.git"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "@vernonthedev/encryptd-darwin-arm64": "0.0.1",
    "@vernonthedev/encryptd-darwin-x64": "0.0.1",
    "@vernonthedev/encryptd-linux-x64-gnu": "0.0.1",
    "@vernonthedev/encryptd-win32-x64-msvc": "0.0.1"
  }
}
