{
  "name": "@vernonthedev/encryptd",
  "version": "0.0.1",
  "author": "vernonthedev",
  "description": "Rust based Env Encryption Package.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "bin": {
    "secure-env": "src/cli.ts"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build"
  },
  "napi": {
    "name": "encryptd",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/vernonthedev/encryptd.git"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
